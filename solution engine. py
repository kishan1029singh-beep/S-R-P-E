def suggest_solution(pollution_index: float) -> str:
    """
    Simple rule-based suggestions based on pollution index.
    Adjust thresholds to match your real model/scale.
    """
    if pollution_index >= 100:
        return "Critical pollution — divert traffic, restrict heavy vehicles, issue public advisory."
    if pollution_index >= 60:
        return "High pollution — optimize signal timings, enforce odd-even or restrictions, encourage public transport."
    if pollution_index >= 30:
        return "Moderate pollution — adjust timings, promote ride-sharing / public transit."
    return "Low pollution — normal operation."
